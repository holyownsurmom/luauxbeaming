SITE_URL=https://luaux.wtf
WORKER_SECRET=must-match-site-WORKER_SECRET
WORKER_ID=worker-1
POLL_INTERVAL_MS=3000
MAX_CONCURRENT_JOBS=8
PAYMENT_WATCH_MS=30000
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# --- Recovery mailbox (unique per secured account) ---
# Preferred: Mailcow — creates a real mailbox per job
# Example (LuauX): addresses rxxxxx@luaux.wtf via mail.luaux.wtf
MAILCOW_API_URL=https://mail.luaux.wtf
MAILCOW_API_KEY=
MAILCOW_DOMAIN=luaux.wtf
MAILCOW_IMAP_HOST=mail.luaux.wtf
MAILCOW_IMAP_PORT=993
# MAILCOW_QUOTA_MB=64
# MAIL_TLS_INSECURE=1

# Fallback: Firstmail disposable API
FIRSTMAIL_API_KEY=

# Fallback: catch-all domain + shared IMAP (unique To: address, one inbox)
# RECOVERY_MAIL_DOMAIN=mail.yourdomain.com
# RECOVERY_IMAP_HOST=mail.yourdomain.com
# RECOVERY_IMAP_USER=inbox@yourdomain.com
# RECOVERY_IMAP_PASS=
# RECOVERY_IMAP_PORT=993
